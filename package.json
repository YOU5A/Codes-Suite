{
    "name": "codes-suite",
    "version": "1.3.0",
    "description": "Codes Suite - Unified Windows Desktop Application",
    "main": "electron/main.js",
    "scripts": {
        "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && C:\\Users\\Yousa\\AppData\\Roaming\\npm\\electron.cmd .\"",
        "build": "vite build && electron-builder",
        "vite:dev": "vite",
        "electron:dev": "C:\\Users\\Yousa\\AppData\\Roaming\\npm\\electron.cmd ."
    },
    "keywords": [],
    "author": "Y0USA",
    "license": "MIT",
    "type": "commonjs",
    "dependencies": {
        "framer-motion": "^12.40.0",
        "lucide-react": "^1.17.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.0",
        "@types/react": "^19.2.16",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "concurrently": "^10.0.1",
        "electron": "^42.3.3",
        "electron-builder": "^26.8.1",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "wait-on": "^9.0.10"
    },
    "build": {
        "appId": "com.yousa.codes-suite",
        "productName": "Codes Suite",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            "bridge/**/*",
            "resources/**/*"
        ],
        "extraResources": [
            {
                "to": "bridge",
                "from": "bridge"
            },
            {
                "to": "resources",
                "from": "resources"
            },
            {
                "to": "icon.ico",
                "from": "icon.ico"
            }
        ],
        "win": {
            "target": [
                "portable",
                "nsis"
            ],
            "icon": "icon.ico",
            "requestedExecutionLevel": "requireAdministrator"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "perMachine": true
        }
    }
}
